# OS
.DS_Store
*.log
*.pid

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.pnpm-store/

# Expo
.expo/
.expo-shared/
dist/
web-build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Native (prebuild output — regenerated via `npx expo prebuild --clean`)
/ios/
/android/

# Testing
coverage/
.nyc_output/

# Editors
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Env
.env
.env.local
.env.*.local

# TypeScript
*.tsbuildinfo

# Memory (per-machine agent memory, not code)
memory/

# Local agent harness scratch (worktrees, tmp state — NOT code)
.claude/

# YOLO training — data + runs live out-of-repo (DVC-tracked).
# Manifests stay in git so license sign-offs are reviewable.
data/raw/
data/frames/
data/labels/
data/splits/
data/eval_slices/
!data/manifests/
runs/
scripts/training/.venv/
scripts/training/__pycache__/
*.pt
*.mlpackage
*.tflite

# Local YOLO-Pose dataset layout — frames/labels live on the training
# box only. Config + README + .gitkeep markers stay in git so the
# folder shape is reviewable.
datasets/climbing-pose/images/**/*
datasets/climbing-pose/labels/**/*
!datasets/climbing-pose/images/**/.gitkeep
!datasets/climbing-pose/labels/**/.gitkeep
